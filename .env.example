# ============================================
# E-Commerce Backend Configuration Template
# ============================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Replace ALL values (see comments)
# 3. Keep .env SECRET - never commit!
# 4. See ENV_SETUP_GUIDE.md for help
# ============================================

# ============================================
# 1. DATABASE CONFIGURATION (SQL Server)
# ============================================
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=ecommerce_marketplace;encrypt=true;trustServerCertificate=true
DB_USERNAME=sa
DB_PASSWORD=your_db_password

# ============================================
# 2. JWT CONFIGURATION (Authentication)
# ============================================
JWT_SECRET=bXktc2VjcmV0LWtleS1mb3ItZWNvbW1lcmNlLW1hcmtldHBsYWNlLXByb2plY3QtMjAyNg==
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ============================================
# 3. EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# ============================================
# 4. CLOUDINARY CONFIGURATION (Image Storage)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# 5. SEPAY PAYMENT GATEWAY (Vietnamese Payment)
# ============================================
SEPAY_API_ID=8574
SEPAY_API_KEY=e-commerce-mini
SEPAY_API_SECRET=your_sepay_secret
SEPAY_API_URL=https://my.sepay.vn/api/v2
SEPAY_WEBHOOK_SECRET=

# ============================================
# 6. APP CONFIGURATION
# ============================================
APP_SEPAY_API_KEY=demo_key
SERVER_PORT=8080

# ============================================
# 7. LOGGING (Development)
# ============================================
LOGGING_LEVEL=DEBUG

